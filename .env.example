# ============================================================
# crypto-clawie 环境变量配置
# 复制此文件为 .env 并填入真实值
# 切勿将 .env 提交到 Git！
# ============================================================

# ── Hyperliquid ──────────────────────────────────────────────
HL_PRIVATE_KEY=0x               # EVM 私钥（必填）
HL_WALLET_ADDRESS=0x            # 对应钱包地址（必填）
HL_USE_TESTNET=false            # true = 测试网
HL_DEFAULT_LEVERAGE=3           # 默认杠杆（1–50）
HL_DEFAULT_MARGIN_MODE=cross    # cross（全仓）| isolated（逐仓）
HL_FUNDING_ALERT_THRESHOLD=0.0005
HL_LIQ_ALERT_THRESHOLD=0.15

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=             # BotFather 获取（必填）
TELEGRAM_CHAT_ID=               # 你的 Chat ID（必填）
TELEGRAM_ALERT_CHAT_ID=        # 预警频道 ID（可选，默认同上）

# ── 新闻 ──────────────────────────────────────────────────────
BLOCKBEATS_API_KEY=             # BlockBeats API Key（推荐）

# ── 调度器 ───────────────────────────────────────────────────
FETCH_INTERVAL_MIN=5            # 市场数据抓取间隔（分钟）
NEWS_INTERVAL_MIN=15            # 新闻抓取间隔（分钟）
DAILY_REPORT_HOUR=8             # 每日报告发送时间（CST）

# ── 安全 ─────────────────────────────────────────────────────
AUTONOMOUS_MODE=false           # true = 允许自动执行交易（谨慎开启）
MAX_POSITION_SIZE_USD=500       # 单笔最大仓位（USD），建议从小值起步
MAX_DAILY_LOSS_PCT=5            # 每日亏损熔断阈值（账户净值百分比）

# ── 自动交易（需先设置 AUTONOMOUS_MODE=true）──────────────────
AUTO_TRADE_ENABLED=false        # 自动交易总开关
AUTO_TRADE_MIN_CONFIDENCE=0.7   # 触发自动开仓的最低信号置信度（0-1）
AUTO_TRADE_SIZE_USD=50          # 每笔自动开仓金额（USD）建议从小值开始
AUTO_TRADE_MAX_POSITIONS=2      # 最多同时持有的自动仓位数
AUTO_TRADE_EXIT_FUNDING=0.0001  # 资金费率低于此值时自动平仓（/8h）
AUTO_TRADE_PROFIT_PCT=3         # 止盈百分比
AUTO_TRADE_STOP_PCT=2           # 止损百分比
